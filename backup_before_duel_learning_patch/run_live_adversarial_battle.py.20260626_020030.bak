from __future__ import annotations

import argparse
import importlib.util
import json
import os
import queue
import subprocess
import sys
import tempfile
import threading
import time
from collections import Counter, deque
from pathlib import Path
from typing import Any

try:
    import tkinter as tk
except Exception:
    tk = None

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from tools import run_adversarial_battle as battle


OUT_DIR = ROOT / "training_outputs"
LIVE_ROUNDS = OUT_DIR / "live_adversarial_battle_rounds.jsonl"
LIVE_SUMMARY = OUT_DIR / "live_adversarial_battle_summary.json"
LIVE_EVAL_INPUT = OUT_DIR / ".live_adversarial_eval_input.jsonl"
LIVE_EVAL_OUTPUT = OUT_DIR / ".live_adversarial_eval_output.json"


def _json_default(value: Any) -> str:
    return str(value)


def _atomic_write_json(path: Path, payload: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, tmp_name = tempfile.mkstemp(prefix=f".{path.name}.", suffix=".tmp", dir=str(path.parent))
    tmp = Path(tmp_name)
    try:
        with os.fdopen(fd, "w", encoding="utf-8", newline="\n") as handle:
            json.dump(payload, handle, ensure_ascii=False, indent=2, sort_keys=True, default=_json_default)
            handle.write("\n")
            handle.flush()
            os.fsync(handle.fileno())
        os.replace(tmp, path)
    finally:
        tmp.unlink(missing_ok=True)


def _atomic_write_jsonl(path: Path, rows: list[dict[str, Any]]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, tmp_name = tempfile.mkstemp(prefix=f".{path.name}.", suffix=".tmp", dir=str(path.parent))
    tmp = Path(tmp_name)
    try:
        with os.fdopen(fd, "w", encoding="utf-8", newline="\n") as handle:
            for row in rows:
                handle.write(json.dumps(row, ensure_ascii=False, sort_keys=True, default=_json_default) + "\n")
            handle.flush()
            os.fsync(handle.fileno())
        os.replace(tmp, path)
    finally:
        tmp.unlink(missing_ok=True)


def _append_jsonl_atomic(path: Path, row: dict[str, Any]) -> None:
    rows = battle._read_jsonl(path)
    rows.append(row)
    _atomic_write_jsonl(path, rows)


def _evaluate_cases_with_tool_python(
    cases: list[dict[str, Any]],
    batch_size: int,
    cpu_workers: int,
    tool_python: str,
) -> tuple[list[dict[str, Any]], float]:
    tool_path = Path(tool_python)
    if not tool_path.exists() or tool_path.resolve() == Path(sys.executable).resolve():
        return battle._evaluate_cases(cases, batch_size, cpu_workers)

    LIVE_EVAL_INPUT.unlink(missing_ok=True)
    LIVE_EVAL_OUTPUT.unlink(missing_ok=True)
    _atomic_write_jsonl(LIVE_EVAL_INPUT, cases)
    started = time.perf_counter()
    proc = subprocess.run(
        [
            str(tool_path),
            str(Path(__file__).resolve()),
            "--evaluate-cases-only",
            str(LIVE_EVAL_INPUT),
            str(LIVE_EVAL_OUTPUT),
            "--batch-size",
            str(batch_size),
            "--cpu-workers",
            str(cpu_workers),
        ],
        cwd=ROOT,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
    )
    elapsed = time.perf_counter() - started
    if proc.returncode == 0 and LIVE_EVAL_OUTPUT.exists():
        payload = battle._read_json(LIVE_EVAL_OUTPUT)
        results = payload.get("results")
        if isinstance(results, list):
            LIVE_EVAL_INPUT.unlink(missing_ok=True)
            LIVE_EVAL_OUTPUT.unlink(missing_ok=True)
            return [row for row in results if isinstance(row, dict)], elapsed

    results, fallback_elapsed = battle._evaluate_cases(cases, batch_size, cpu_workers)
    for result in results:
        if result.get("severity") == "error":
            result["suggested_optimizer_rule"] = (
                f"{result.get('suggested_optimizer_rule', '')}; delegated venv evaluation failed "
                f"with return code {proc.returncode}: {proc.stdout[-500:]}"
            )
    return results, elapsed + fallback_elapsed


def _torch_status() -> dict[str, Any]:
    status: dict[str, Any] = {
        "torch_installed": False,
        "cuda_available": False,
        "gpu_name": None,
        "torch_error": None,
    }
    try:
        import torch
    except Exception as exc:
        status["torch_error"] = f"{type(exc).__name__}: {exc}"
        return status

    status["torch_installed"] = True
    try:
        status["cuda_available"] = bool(torch.cuda.is_available())
        if status["cuda_available"]:
            status["gpu_name"] = torch.cuda.get_device_name(0)
    except Exception as exc:
        status["torch_error"] = f"{type(exc).__name__}: {exc}"
        status["cuda_available"] = False
    return status


def _evaluation_mode(args: argparse.Namespace, torch_status: dict[str, Any]) -> dict[str, Any]:
    workers = max(1, int(args.cpu_workers))
    cpu_mode = "cpu_threaded" if workers > 1 else "cpu_serial"
    if not args.use_gpu:
        return {
            "actual_evaluation_mode": cpu_mode,
            "gpu_backend_used": False,
            "cpu_only_reason": "GPU evaluation was not requested.",
        }
    if not torch_status.get("torch_installed"):
        return {
            "actual_evaluation_mode": cpu_mode,
            "gpu_backend_used": False,
            "cpu_only_reason": f"PyTorch is not importable: {torch_status.get('torch_error') or 'unknown import error'}",
        }
    if not torch_status.get("cuda_available"):
        return {
            "actual_evaluation_mode": cpu_mode,
            "gpu_backend_used": False,
            "cpu_only_reason": "CUDA is unavailable; whole-profile optimizer damage evaluation ran on CPU.",
        }
    return {
        "actual_evaluation_mode": "gpu_batch_ready",
        "gpu_backend_used": False,
        "cpu_only_reason": "",
    }


def _print_startup(torch_status: dict[str, Any], mode: dict[str, Any]) -> None:
    print(f"torch installed: {torch_status['torch_installed']}", flush=True)
    print(f"cuda available: {torch_status['cuda_available']}", flush=True)
    print(f"GPU name: {torch_status.get('gpu_name') or 'none'}", flush=True)
    print(f"actual_evaluation_mode: {mode['actual_evaluation_mode']}", flush=True)
    print(f"cpu_only_reason: {mode.get('cpu_only_reason') or ''}", flush=True)


class RunControl:
    def __init__(self, args: argparse.Namespace) -> None:
        self.mode = str(args.run_mode or "rounds")
        self.minutes = float(args.minutes or 0.0)
        self.stop_after_round = threading.Event()
        self.stop_now = threading.Event()
        self._lock = threading.Lock()
        self._deadline: float | None = None
        if self.mode == "timed":
            self._deadline = time.time() + max(0.01, self.minutes) * 60.0

    def add_minutes(self, minutes: float) -> None:
        with self._lock:
            if self._deadline is None:
                self._deadline = time.time()
            self._deadline += float(minutes) * 60.0

    def request_stop_after_round(self) -> None:
        self.stop_after_round.set()

    def request_stop_now(self) -> None:
        self.stop_now.set()
        self.stop_after_round.set()

    def end_early(self) -> None:
        self.request_stop_after_round()

    def time_remaining(self) -> float | None:
        with self._lock:
            if self._deadline is None:
                return None
            return max(0.0, self._deadline - time.time())

    def should_start_round(self, completed_rounds: int, requested_rounds: int) -> bool:
        if self.stop_now.is_set() or self.stop_after_round.is_set():
            return False
        if self.mode == "endless":
            return True
        if self.mode == "timed":
            remaining = self.time_remaining()
            return remaining is None or remaining > 0
        return completed_rounds < max(0, int(requested_rounds))


def _format_seconds(seconds: float | None) -> str:
    if seconds is None:
        return "n/a"
    seconds = max(0, int(seconds))
    h = seconds // 3600
    m = (seconds % 3600) // 60
    s = seconds % 60
    if h:
        return f"{h}h {m}m {s}s"
    return f"{m}m {s}s"


def _learning_status(history: list[float]) -> str:
    if len(history) < 4:
        return "Learning: warming up"
    recent = history[-4:]
    delta = recent[-1] - recent[0]
    if delta > 0.015:
        return "Learning: improving"
    if delta < -0.015:
        return "Learning: regressing"
    return "Learning: plateauing"


class _LiveAdversarialBattleDashboard:
    def __init__(self, control: RunControl) -> None:
        if tk is None:
            raise RuntimeError("tkinter is not available")
        self.control = control
        self.root = tk.Tk()
        self.root.title("Live Adversarial Battle Dashboard")
        self.root.geometry("980x760")
        self.root.protocol("WM_DELETE_WINDOW", self._on_close)

        self.queue: queue.Queue[dict[str, Any]] = queue.Queue()
        self.history: list[float] = []
        self.fail_history: list[float] = []
        self.last_payload: dict[str, Any] = {}
        self.done = False
        self.worker: threading.Thread | None = None

        self.status = tk.Label(self.root, text="Starting...", anchor="w", font=("Segoe UI", 11, "bold"))
        self.status.pack(fill="x", padx=8, pady=4)

        button_frame = tk.Frame(self.root)
        button_frame.pack(fill="x", padx=8, pady=4)

        tk.Button(button_frame, text="Stop after current round", command=self.control.request_stop_after_round).pack(side="left", padx=3)
        tk.Button(button_frame, text="Stop now", command=self.control.request_stop_now).pack(side="left", padx=3)
        tk.Button(button_frame, text="End early", command=self.control.end_early).pack(side="left", padx=3)
        tk.Button(button_frame, text="+5 min", command=lambda: self.control.add_minutes(5)).pack(side="left", padx=3)
        tk.Button(button_frame, text="+15 min", command=lambda: self.control.add_minutes(15)).pack(side="left", padx=3)
        tk.Button(button_frame, text="+30 min", command=lambda: self.control.add_minutes(30)).pack(side="left", padx=3)
        tk.Button(button_frame, text="+1 hour", command=lambda: self.control.add_minutes(60)).pack(side="left", padx=3)

        body = tk.Frame(self.root)
        body.pack(fill="both", expand=True, padx=8, pady=4)

        left = tk.Frame(body)
        left.pack(side="left", fill="both", expand=True)

        right = tk.Frame(body)
        right.pack(side="right", fill="both", expand=True)

        self.labels: dict[str, tk.Label] = {}
        rows = [
            "Run mode",
            "Time remaining",
            "Round",
            "Profiles tested",
            "Pass",
            "Fail",
            "Accuracy",
            "Failure rate",
            "Wall profiles/sec",
            "Scoring profiles/sec",
            "GPU rows scored",
            "GPU rows submitted",
            "GPU idle",
            "Evaluation mode",
            "Hard examples saved",
            "Plateau status",
            "Top failure",
            "Bottleneck",
        ]
        for index, label_text in enumerate(rows):
            label = tk.Label(left, text=f"{label_text}: ", anchor="w", justify="left", width=62)
            label.grid(row=index, column=0, sticky="w", padx=4, pady=2)
            self.labels[label_text] = label

        tk.Label(right, text="Worst failure categories", anchor="w", font=("Segoe UI", 10, "bold")).pack(fill="x")
        self.fail_text = tk.Text(right, height=13, width=48)
        self.fail_text.pack(fill="both", expand=False)

        tk.Label(right, text="Intelligence graph: accuracy and moving average", anchor="w", font=("Segoe UI", 10, "bold")).pack(fill="x", pady=(8, 2))
        self.canvas = tk.Canvas(right, width=430, height=260, bg="white")
        self.canvas.pack(fill="both", expand=True)

        self.root.after(100, self._tick)

    def _on_close(self) -> None:
        self.control.request_stop_after_round()
        try:
            self.root.destroy()
        except Exception:
            pass

    def push(self, payload: dict[str, Any]) -> None:
        self.queue.put(payload)

    def start(self, worker: threading.Thread) -> None:
        self.worker = worker
        self.root.mainloop()

    def _tick(self) -> None:
        try:
            while True:
                payload = self.queue.get_nowait()
                if payload.get("__done__"):
                    self.done = True
                    if payload.get("fatal_error"):
                        self.status.config(text=f"Done with fatal error: {payload.get('fatal_error')}")
                    else:
                        self.status.config(text="Done. Close the window when finished reviewing.")
                    continue
                self._update_payload(payload)
        except queue.Empty:
            pass

        if not self.done:
            if self.control.stop_after_round.is_set():
                self.status.config(text="Stop requested. Waiting for current round to finish cleanly...")
            else:
                self.status.config(text="Running")
        try:
            self.root.after(250, self._tick)
        except Exception:
            pass

    def _update_payload(self, payload: dict[str, Any]) -> None:
        self.last_payload = payload
        tested = int(payload.get("profiles_tested", 0) or 0)
        passed = int(payload.get("pass_count", 0) or 0)
        failed = int(payload.get("fail_count", 0) or 0)
        accuracy = passed / max(1, tested)
        fail_rate = failed / max(1, tested)
        self.history.append(accuracy)
        self.fail_history.append(fail_rate)
        self.history = self.history[-200:]
        self.fail_history = self.fail_history[-200:]
        plateau = _learning_status(self.history)

        total_hard = 0
        hard_path = OUT_DIR / "adversarial_hard_examples.jsonl"
        if hard_path.exists():
            try:
                total_hard = len([line for line in hard_path.read_text(encoding="utf-8").splitlines() if line.strip()])
            except Exception:
                total_hard = 0

        values = {
            "Run mode": str(payload.get("run_mode", self.control.mode)),
            "Time remaining": _format_seconds(self.control.time_remaining()),
            "Round": f"{payload.get('round', 0)}/{payload.get('rounds_requested', '')}",
            "Profiles tested": str(tested),
            "Pass": str(passed),
            "Fail": str(failed),
            "Accuracy": f"{accuracy * 100:.2f}%",
            "Failure rate": f"{fail_rate * 100:.2f}%",
            "Wall profiles/sec": str(payload.get("profiles_per_sec_wall", 0.0)),
            "Scoring profiles/sec": str(payload.get("profiles_per_sec_scoring_only", 0.0)),
            "GPU rows scored": str(payload.get("gpu_rows_scored", 0)),
            "GPU rows submitted": str(payload.get("gpu_rows_submitted", 0)),
            "GPU idle": str(payload.get("gpu_idle_estimate", 0.0)),
            "Evaluation mode": str(payload.get("actual_evaluation_mode", "")),
            "Hard examples saved": str(total_hard),
            "Plateau status": plateau,
            "Top failure": str(payload.get("top_fail", "none")),
            "Bottleneck": str(payload.get("next_perf_bottleneck", "")),
        }
        for label_text, label in self.labels.items():
            label.config(text=f"{label_text}: {values.get(label_text, '')}")

        self.fail_text.delete("1.0", "end")
        failures = payload.get("failure_categories") or {}
        ranked = sorted(failures.items(), key=lambda item: int(item[1]), reverse=True)
        if not ranked:
            self.fail_text.insert("end", "No failures yet.\n")
        for index, (name, count) in enumerate(ranked[:12], start=1):
            self.fail_text.insert("end", f"{index}. {name}: {count}\n")

        self._draw_graph()

    def _draw_graph(self) -> None:
        canvas = self.canvas
        canvas.delete("all")
        w = max(300, int(canvas.winfo_width() or 430))
        h = max(220, int(canvas.winfo_height() or 260))
        pad = 32
        canvas.create_line(pad, h - pad, w - pad, h - pad)
        canvas.create_line(pad, pad, pad, h - pad)
        canvas.create_text(pad + 20, pad - 10, text="100%")
        canvas.create_text(pad + 15, h - pad + 12, text="0%")

        if len(self.history) < 2:
            canvas.create_text(w // 2, h // 2, text="Waiting for more rounds...")
            return

        data = self.history
        n = len(data)
        points = []
        for i, value in enumerate(data):
            x = pad + (w - 2 * pad) * (i / max(1, n - 1))
            y = h - pad - (h - 2 * pad) * max(0.0, min(1.0, value))
            points.extend([x, y])
        if len(points) >= 4:
            canvas.create_line(*points, width=2)

        ma = []
        for i in range(n):
            window = data[max(0, i - 4): i + 1]
            ma.append(sum(window) / len(window))
        ma_points = []
        for i, value in enumerate(ma):
            x = pad + (w - 2 * pad) * (i / max(1, n - 1))
            y = h - pad - (h - 2 * pad) * max(0.0, min(1.0, value))
            ma_points.extend([x, y])
        if len(ma_points) >= 4:
            canvas.create_line(*ma_points, width=3, dash=(4, 2))

        canvas.create_text(w // 2, h - 8, text=f"{_learning_status(self.history)} | latest accuracy {self.history[-1] * 100:.2f}%")


def _create_dashboard(control: RunControl) -> Any:
    if tk is None:
        return None
    try:
        return _LiveAdversarialBattleDashboard(control)
    except Exception as exc:
        print(f"dashboard initialization failed: {type(exc).__name__}: {exc}", flush=True)
        return None


def _import_status(module: str) -> str:
    return "Yes" if importlib.util.find_spec(module) else "NOT_FOUND"


def _debug_routing(args: argparse.Namespace) -> int:
    torch_status = _torch_status()
    mode = _evaluation_mode(args, torch_status)
    delegated = Path(battle._python_for_subprocesses()).exists() and Path(battle._python_for_subprocesses()).resolve() != Path(sys.executable).resolve()
    rejection = mode.get("cpu_only_reason") or "none"
    print(f"torch_installed: {torch_status['torch_installed']} | cuda_available: {torch_status['cuda_available']} | gpu_name: {torch_status.get('gpu_name') or 'none'} | raw_use_gpu_flag_value: {args.use_gpu}")
    print(f"selected_eval_backend: {'gpu_batch' if mode['actual_evaluation_mode'] == 'gpu_batch_ready' else 'cpu_threadpool'} | selected_actual_evaluation_mode: {mode['actual_evaluation_mode']}")
    print(f"gpu_scoring_import_status: {_import_status('tools.gpu_scoring')} | gpu_batch_engine_import_status: {_import_status('optimizer.gpu_batch_engine')} | profile_to_matrix_adapter_exists: {_import_status('optimizer.profile_to_matrix_adapter') == 'Yes'}")
    print(f"cpu_evaluator_selected: {not mode['gpu_backend_used']} | subprocess_or_venv_delegation_used: {delegated}")
    print(f"gpu_rejection_reason: {rejection} | cpu_underutilization_reason: synchronous_training_subprocess_or_threadpool_starvation")
    return 0


def _top_fail(failures: list[dict[str, Any]]) -> str:
    if not failures:
        return "none"
    counts = Counter(battle._normalize_category(row.get("category")) for row in failures)
    return counts.most_common(1)[0][0]


def _round_label(args: argparse.Namespace) -> str:
    if args.run_mode == "endless":
        return "endless"
    if args.run_mode == "timed":
        return f"timed:{args.minutes:g}m"
    return str(int(args.rounds))


def _round_payload(
    round_no: int,
    args: argparse.Namespace,
    cases: list[dict[str, Any]],
    results: list[dict[str, Any]],
    cpu_generation_time: float,
    scoring_time: float,
    round_wall_time: float,
    new_cases_added: int,
    mode: dict[str, Any],
    training_run: dict[str, Any],
    gpu_stats: dict[str, Any] | None = None,
) -> dict[str, Any]:
    failures = [row for row in results if not row.get("passed")]
    tested = len(results)
    wall_p_s = tested / round_wall_time if round_wall_time > 0 else 0.0
    score_p_s = tested / scoring_time if scoring_time > 0 else 0.0
    failure_categories = Counter(battle._normalize_category(row.get("category")) for row in failures)
    severity_counts = Counter(str(row.get("severity") or "unknown") for row in failures)
    target_reached = wall_p_s >= float(args.target_profiles_per_sec)
    gpu_stats = gpu_stats or {}
    gpu_rows = int(gpu_stats.get("gpu_rows_scored", 0) or 0)
    gpu_batches = int(gpu_stats.get("gpu_batches_scored", 0) or 0)
    actual_mode = "gpu_batch" if gpu_rows > 0 else ("cpu_threaded" if int(args.cpu_workers) > 1 else "cpu_serial")
    gpu_idle = 0.0 if gpu_rows > 0 else (1.0 if args.use_gpu else 0.0)
    return {
        "round": round_no,
        "rounds_requested": _round_label(args),
        "run_mode": str(args.run_mode),
        "minutes": float(args.minutes or 0.0),
        "profiles_tested": tested,
        "pass_count": tested - len(failures),
        "fail_count": len(failures),
        "profiles_per_sec_wall": round(wall_p_s, 6),
        "profiles_per_sec_scoring_only": round(score_p_s, 6),
        "target_profiles_per_sec": float(args.target_profiles_per_sec),
        "target_reached": target_reached,
        "cpu_generation_time": round(cpu_generation_time, 6),
        "scoring_time": round(scoring_time, 6),
        "round_wall_time": round(round_wall_time, 6),
        "gpu_rows_submitted": int(gpu_stats.get("gpu_rows_submitted", 0) or 0),
        "gpu_rows_scored": gpu_rows,
        "gpu_batches_scored": gpu_batches,
        "gpu_seconds": round(float(gpu_stats.get("gpu_seconds", 0.0) or 0.0), 6),
        "gpu_idle_estimate": gpu_idle,
        "new_cases_added": new_cases_added,
        "failure_categories": dict(sorted(failure_categories.items())),
        "severity_counts": dict(sorted(severity_counts.items())),
        "top_fail": _top_fail(failures),
        "top_rules_to_fix": battle._top_rules(failures),
        "next_perf_bottleneck": battle._bottleneck(
            cpu_generation_time,
            scoring_time,
            bool(args.use_gpu),
            gpu_rows,
            target_reached,
        ),
        "actual_evaluation_mode": actual_mode,
        "gpu_backend_used": gpu_rows > 0,
        "cpu_only_reason": "" if gpu_rows > 0 else mode.get("cpu_only_reason"),
        "parity_checked": bool(gpu_stats.get("parity_checked")),
        "parity_passed": bool(gpu_stats.get("parity_passed")),
        "training_subprocess": training_run,
    }


def _summary(
    args: argparse.Namespace,
    round_rows: list[dict[str, Any]],
    torch_status: dict[str, Any],
    mode: dict[str, Any],
    fatal_error: str | None = None,
) -> dict[str, Any]:
    completed = len(round_rows)
    total_profiles = sum(int(row.get("profiles_tested", 0)) for row in round_rows)
    wall_speeds = [float(row.get("profiles_per_sec_wall", 0.0)) for row in round_rows]
    score_times = sum(float(row.get("scoring_time", 0.0)) for row in round_rows)
    failure_categories: Counter[str] = Counter()
    severity_counts: Counter[str] = Counter()
    rules: Counter[str] = Counter()
    for row in round_rows:
        failure_categories.update({str(k): int(v) for k, v in (row.get("failure_categories") or {}).items()})
        severity_counts.update({str(k): int(v) for k, v in (row.get("severity_counts") or {}).items()})
        for rule in row.get("top_rules_to_fix") or []:
            rules[str(rule)] += 1

    gpu_rows = sum(int(row.get("gpu_rows_scored", 0)) for row in round_rows)
    return {
        "run_mode": str(args.run_mode),
        "minutes": float(args.minutes or 0.0),
        "rounds_requested": _round_label(args),
        "rounds_completed": completed,
        "stopped_early": bool(fatal_error) or (args.run_mode == "rounds" and completed < int(args.rounds)),
        "fatal_error": fatal_error,
        "total_profiles_tested": total_profiles,
        "total_failures_found": sum(int(row.get("fail_count", 0)) for row in round_rows),
        "total_new_cases_added": sum(int(row.get("new_cases_added", 0)) for row in round_rows),
        "average_profiles_per_sec_wall": round(sum(wall_speeds) / len(wall_speeds), 6) if wall_speeds else 0.0,
        "best_profiles_per_sec_wall": round(max(wall_speeds), 6) if wall_speeds else 0.0,
        "profiles_per_sec_scoring_only": round(total_profiles / score_times, 6) if score_times > 0 else 0.0,
        "cuda_available": bool(torch_status.get("cuda_available")),
        "gpu_name": torch_status.get("gpu_name"),
        "actual_evaluation_mode": "gpu_batch" if gpu_rows > 0 else mode["actual_evaluation_mode"],
        "gpu_backend_used": gpu_rows > 0,
        "gpu_rows_submitted": sum(int(row.get("gpu_rows_submitted", 0)) for row in round_rows),
        "gpu_rows_scored": gpu_rows,
        "gpu_batches_scored": sum(int(row.get("gpu_batches_scored", 0)) for row in round_rows),
        "gpu_seconds": round(sum(float(row.get("gpu_seconds", 0.0)) for row in round_rows), 6),
        "gpu_idle_estimate": round(sum(float(row.get("gpu_idle_estimate", 0.0)) for row in round_rows) / len(round_rows), 6) if round_rows else 0.0,
        "cpu_only_reason": "" if gpu_rows > 0 else mode.get("cpu_only_reason"),
        "remaining_failure_categories": dict(sorted(failure_categories.items())),
        "severity_counts": dict(sorted(severity_counts.items())),
        "top_rules_to_fix": [rule for rule, _ in rules.most_common(5)],
        "next_perf_bottleneck": str(round_rows[-1].get("next_perf_bottleneck", "")) if round_rows else "",
        "torch_installed": bool(torch_status.get("torch_installed")),
        "torch_error": torch_status.get("torch_error"),
    }


def parse_args(argv: list[str] | None = None) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Run live adversarial optimizer battle telemetry.")
    parser.add_argument("--rounds", type=int, default=5)
    parser.add_argument("--batch-size", type=int, default=512)
    parser.add_argument("--max-generated-per-round", type=int, default=2000)
    parser.add_argument("--target-profiles-per-sec", type=float, default=20.0)
    parser.add_argument("--use-gpu", action="store_true")
    parser.add_argument("--cpu-workers", type=int, default=8)
    parser.add_argument("--dashboard", action="store_true", help="Show a Tkinter dashboard with live stats, controls, and graph.")
    parser.add_argument("--run-mode", choices=["rounds", "endless", "timed"], default="rounds")
    parser.add_argument("--minutes", type=float, default=5.0)
    parser.add_argument("--live", action="store_true")
    parser.add_argument("--debug-routing", action="store_true")
    parser.add_argument("--skip-baseline", action="store_true")
    return parser.parse_args(argv)


def run(args: argparse.Namespace, dashboard: Any | None = None, control: RunControl | None = None) -> int:
    OUT_DIR.mkdir(parents=True, exist_ok=True)
    LIVE_ROUNDS.unlink(missing_ok=True)

    control = control or RunControl(args)
    torch_status = _torch_status()
    mode = _evaluation_mode(args, torch_status)
    _print_startup(torch_status, mode)

    tool_python = battle._python_for_subprocesses()
    training_module = battle._load_training_module()
    round_rows: list[dict[str, Any]] = []

    round_no = 0
    while control.should_start_round(round_no, int(args.rounds)):
        round_no += 1
        round_started = time.perf_counter()
        training_run = (
            {"command": "skip-baseline", "returncode": 0, "elapsed_seconds": 0.0, "output_tail": ""}
            if args.skip_baseline
            else battle._run_training_subprocess(tool_python)
        )
        training_summary = battle._read_json(battle.TRAINING_SUMMARY)
        stored_cases = battle._read_jsonl(battle.ADVERSARIAL_CASES)
        seed_cases = battle._load_seed_cases(training_module)
        active_categories = battle._active_failure_categories(training_summary, stored_cases)
        battle_cases, cpu_generation_time = battle._generate_battle_cases(
            seed_cases,
            active_categories,
            round_no,
            max(0, int(args.max_generated_per_round)),
            max(1, int(args.cpu_workers)),
        )

        if args.use_gpu:
            results, scoring_time, gpu_stats = battle._evaluate_cases_batched(
                battle_cases,
                max(1, int(args.batch_size)),
                max(1, int(args.cpu_workers)),
                True,
            )
        else:
            results, scoring_time = _evaluate_cases_with_tool_python(
                battle_cases,
                max(1, int(args.batch_size)),
                max(1, int(args.cpu_workers)),
                tool_python,
            )
            gpu_stats = {"gpu_used": False, "gpu_rows_scored": 0, "gpu_batches_scored": 0}

        new_cases_added = battle._append_new_failure_cases(round_no, battle_cases, results)
        round_wall_time = time.perf_counter() - round_started
        payload = _round_payload(
            round_no,
            args,
            battle_cases,
            results,
            cpu_generation_time,
            scoring_time,
            round_wall_time,
            new_cases_added,
            mode,
            training_run,
            gpu_stats,
        )
        _append_jsonl_atomic(LIVE_ROUNDS, payload)
        round_rows.append(payload)
        _atomic_write_json(LIVE_SUMMARY, _summary(args, round_rows, torch_status, mode))

        if dashboard:
            dashboard.push(payload)

        print(
            f"Round {round_no}/{_round_label(args)} | tested={payload['profiles_tested']} | "
            f"pass={payload['pass_count']} | fail={payload['fail_count']} | "
            f"wall_p/s={payload['profiles_per_sec_wall']} | score_p/s={payload['profiles_per_sec_scoring_only']} | "
            f"gpu_rows={payload['gpu_rows_scored']} | gpu_idle={payload['gpu_idle_estimate']} | "
            f"new_cases={payload['new_cases_added']} | top_fail={payload['top_fail']} | "
            f"bottleneck={payload['next_perf_bottleneck']}",
            flush=True,
        )

        if control.stop_now.is_set() or control.stop_after_round.is_set():
            print("stop requested; saved summary and ending cleanly", flush=True)
            break

    _atomic_write_json(LIVE_SUMMARY, _summary(args, round_rows, torch_status, mode))
    if dashboard:
        dashboard.push({"__done__": True})
    return 0


def _run_dashboard_mode(args: argparse.Namespace) -> int:
    control = RunControl(args)
    dashboard = _create_dashboard(control)
    if dashboard is None:
        return run(args, None, control)

    result: dict[str, Any] = {"code": 1, "fatal_error": None}

    def worker() -> None:
        try:
            result["code"] = run(args, dashboard, control)
        except Exception as exc:
            result["fatal_error"] = f"{type(exc).__name__}: {exc}"
            existing_rounds = battle._read_jsonl(LIVE_ROUNDS)
            torch_status = _torch_status()
            mode = _evaluation_mode(args, torch_status)
            _atomic_write_json(LIVE_SUMMARY, _summary(args, existing_rounds, torch_status, mode, fatal_error=result["fatal_error"]))
            dashboard.push({"__done__": True, "fatal_error": result["fatal_error"]})

    thread = threading.Thread(target=worker, name="live-battle-worker", daemon=True)
    thread.start()
    dashboard.start(thread)
    control.request_stop_after_round()
    thread.join(timeout=10.0)
    return int(result.get("code", 1) or 0)


def main(argv: list[str] | None = None) -> int:
    raw_argv = sys.argv[1:] if argv is None else argv
    if raw_argv and raw_argv[0] == "--evaluate-cases-only":
        input_path = Path(raw_argv[1])
        output_path = Path(raw_argv[2])
        child_parser = argparse.ArgumentParser()
        child_parser.add_argument("--batch-size", type=int, default=512)
        child_parser.add_argument("--cpu-workers", type=int, default=8)
        child_args = child_parser.parse_args(raw_argv[3:])
        cases = battle._read_jsonl(input_path)
        results, scoring_time = battle._evaluate_cases(
            cases,
            max(1, int(child_args.batch_size)),
            max(1, int(child_args.cpu_workers)),
        )
        _atomic_write_json(output_path, {"results": results, "scoring_time": scoring_time})
        return 0

    args = parse_args(argv)
    if args.debug_routing:
        return _debug_routing(args)

    torch_status = _torch_status()
    mode = _evaluation_mode(args, torch_status)
    try:
        if args.dashboard:
            return _run_dashboard_mode(args)
        return run(args)
    except Exception as exc:
        fatal = f"{type(exc).__name__}: {exc}"
        existing_rounds = battle._read_jsonl(LIVE_ROUNDS)
        _atomic_write_json(LIVE_SUMMARY, _summary(args, existing_rounds, torch_status, mode, fatal_error=fatal))
        print(f"fatal_error: {fatal}", flush=True)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
